{
  "name": "@flowrr/cli",
  "version": "0.1.2",
  "description": "CLI for `flower` - scaffold structured development workflows",
  "bin": {
    "flower": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "bun build ./src/main.ts --outdir ./dist --target node && bun run copy:skills && bun run copy:commands",
    "dev": "bun run ./src/main.ts",
    "typecheck": "tsc --noEmit",
    "copy:skills": "rm -rf dist/skills && cp -r ../../skills dist/skills",
    "copy:commands": "rm -rf dist/commands && cp -r ../../commands dist/commands"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "citty": "^0.2.2",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
