{
  "name": "@flower/cli",
  "version": "0.0.1",
  "bin": {
    "flower": "./dist/main.ts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/main.ts",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/main.ts --outdir ./dist --target node",
    "dev": "bun run ./src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  }
}
